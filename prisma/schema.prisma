generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum QuoteStatus {
  DRAFT
  SUBMITTED
  PAID
}

enum SubscriptionPlan {
  PRINT
  ONLINE
  PRINT_ONLINE
}

enum CurrencyCode {
  INR
  USD
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  role         UserRole @default(USER)
  provider     String   @default("credentials")
  providerId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  proformaQuotes ProformaQuote[] @relation("ProformaCreatedBy")
}

model ClonedPage {
  id          String   @id @default(cuid())
  path        String   @unique
  sourceUrl   String
  title       String?
  htmlContent String   @db.Text
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model ProformaQuote {
  id            String             @id @default(cuid())
  organization  String
  contactName   String
  email         String
  phone         String
  country       String
  address       String?
  gstNumber     String?
  currency      CurrencyCode       @default(INR)
  status        QuoteStatus        @default(DRAFT)
  items         ProformaQuoteItem[]
  couponCode    String?
  couponPercent Int                @default(0)
  hasVisitedCheckout Boolean       @default(false)
  adminRemarks  String?            @db.Text
  createdByUserId String?
  createdBy     User?              @relation("ProformaCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model ProformaQuoteItem {
  id               String           @id @default(cuid())
  quoteId          String
  quote            ProformaQuote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  serialNo         Int
  subject          String
  journalName      String
  abbreviation     String
  issn             String?
  selectedPlan     SubscriptionPlan
  currency         CurrencyCode
  unitPrice        Int
  createdAt        DateTime         @default(now())
}

enum CouponType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id             String      @id @default(cuid())
  code           String      @unique
  discount       Int         @default(0) // For fallback compatibility
  type           CouponType  @default(PERCENTAGE)
  value          Float       @default(0)
  maxUses        Int?
  usedCount      Int         @default(0)
  minOrderAmount Float       @default(0)
  validFrom      DateTime?
  validUntil     DateTime?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Order {
  id             String      @id @default(cuid())
  userId         String?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName   String
  email          String
  organization   String?
  address        String
  state          String
  pincode        String
  gstNumber      String?
  quoteId        String?
  currency       CurrencyCode @default(INR)
  subtotal       Int
  discount       Int         @default(0)
  cgst           Float       @default(0)
  sgst           Float       @default(0)
  total          Float
  couponCode     String?
  status         OrderStatus @default(PENDING)
  items          OrderItem[]
  razorpayOrderId String?
  razorpayPaymentId String?
  razorpaySignature String?
  adminRemarks   String?           @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  journalName  String
  subject      String
  issn         String?
  image        String?
  year         String
  issue        String?
  selectedPlan SubscriptionPlan
  unitPrice    Int
  qty          Int      @default(1)
  createdAt    DateTime @default(now())
}

model ContactEntry {
  id         String        @id @default(cuid())
  name       String
  email      String
  phone      String?
  subject    String
  message    String
  status     ContactStatus @default(NEW)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model AgencyQuery {
  id            String   @id @default(cuid())
  agencyName    String
  contactPerson String
  email         String
  phone         String
  country       String
  website       String?
  specialization String
  message       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., USER_WELCOME, ORDER_CONFIRMED_ADMIN
  subject     String
  body        String   @db.Text
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

