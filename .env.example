# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
# IMPORTANT: never put real secrets in this example file — it is committed to git.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stm_shop_clone?schema=public"
SOURCE_SITE_URL="https://shop.stmjournals.com"

# Generate a strong random secret, e.g.:  openssl rand -base64 32
JWT_SECRET="<generate-with: openssl rand -base64 32>"

NEXT_PUBLIC_APP_URL="http://127.0.0.1:3000"

# From Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID="<your-google-oauth-client-id>"
GOOGLE_CLIENT_SECRET="<your-google-oauth-client-secret>"

# Comma-separated list of emails that should receive ADMIN role
ADMIN_EMAILS="admin@example.com"

# Payments (Razorpay dashboard)
RAZORPAY_KEY_ID="<your-razorpay-key-id>"
RAZORPAY_KEY_SECRET="<your-razorpay-key-secret>"
# Razorpay webhook secret (Dashboard > Settings > Webhooks). Used by /api/webhooks/razorpay.
RAZORPAY_WEBHOOK_SECRET="<your-razorpay-webhook-secret>"
# Set to "true" ONLY after enabling international (USD) payments on the Razorpay account.
# Until then, USD quote checkout is blocked gracefully instead of mischarging in INR.
ENABLE_USD_CHECKOUT="false"

# Email (AWS SES)
AWS_REGION="us-west-2"
AWS_ACCESS_KEY_ID="<your-aws-access-key-id>"
AWS_SECRET_ACCESS_KEY="<your-aws-secret-access-key>"
AWS_FROM_EMAIL="noreply@example.com"

# Optional: dedicated secret for hashing email OTPs (falls back to JWT_SECRET if unset)
AUTH_SECRET="<optional-generate-with: openssl rand -base64 32>"
